# Cloudflare R2 sync credentials
# Create an API token at https://dash.cloudflare.com/ → R2 → Manage R2 API Tokens
# with "Object Read & Write" permission on the "hold-your-voice-blobs" bucket.

HYV_R2_ACCESS_KEY_ID=your-access-key-id
HYV_R2_SECRET_ACCESS_KEY=your-secret-access-key
HYV_R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
HYV_R2_BUCKET=hold-your-voice-blobs
